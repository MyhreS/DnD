{
  "name": "catacombs-and-starspawns",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Companion app for our Catacombs & Starspawns tabletop campaign.",
  "scripts": {
    "dev": "doppler run -- vite",
    "build": "tsc -b && doppler run -- vite build",
    "build:ci": "tsc -b && vite build",
    "preview": "doppler run -- vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "deadcode": "knip",
    "deadcode:fix": "knip --fix --allow-remove-files",
    "check": "tsc -b && eslint . && knip",
    "token": "doppler run -- bun scripts/mint-test-token.mjs",
    "e2e": "doppler run -- bun scripts/e2e.mjs",
    "icons": "bun run scripts/generate-icons.mjs",
    "deploy": "bun run build && firebase deploy",
    "deploy:hosting": "bun run build && firebase deploy --only hosting",
    "deploy:rules": "firebase deploy --only firestore:rules"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "date-fns": "^4.1.0",
    "firebase": "^11.3.0",
    "jspdf": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.5",
    "three": "^0.184.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "babel-plugin-react-compiler": "^19.0.0-beta-3229e95-20250315",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "firebase-admin": "^14.0.0",
    "globals": "^15.14.0",
    "knip": "^5.42.0",
    "playwright": "^1.61.0",
    "sharp": "^0.33.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.1.0",
    "vite-plugin-pwa": "^0.21.1"
  },
  "trustedDependencies": [
    "@firebase/util",
    "protobufjs"
  ]
}
