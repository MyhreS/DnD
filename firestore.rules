rules_version = '2';

// Catacombs & Starspawns — Firestore security rules.
//
// Access model:
//  - You must be signed in with Google.
//  - You must be on the allowlist (a document in /allowlist keyed by your email).
//  - The allowlist itself is only writable by trusted backends (Admin SDK /
//    Firebase console / seed script), never from the client.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function emailKey() {
      return request.auth.token.email;
    }

    // Super-admins are always allowed and can manage the allowlist. This
    // bootstraps the first user so the allowlist never needs hand-editing.
    // Keep in sync with src/config.ts (SUPER_ADMIN_EMAILS).
    function isSuperAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && emailKey() in ["simonmyhre1@gmail.com"];
    }

    // True when the signed-in user is a super-admin OR has a doc in /allowlist.
    function isAllowlisted() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && (
          isSuperAdmin()
          || exists(/databases/$(database)/documents/allowlist/$(emailKey()))
        );
    }

    // The signed-in member's allowlist entry data.
    function myData() {
      return get(/databases/$(database)/documents/allowlist/$(emailKey())).data;
    }

    // Access control: admin can manage members; admins/moderators are elevated.
    function isAdmin() {
      return isSuperAdmin() || (isAllowlisted() && myData().accessRole == "admin");
    }

    // "Staff" run sessions & oversight: admins, moderators, or the DM.
    function isStaff() {
      return isSuperAdmin()
        || (isAllowlisted()
            && (myData().accessRole in ["admin", "moderator"] || myData().playerType == "dm"));
    }

    // /allowlist/{email}
    // Members can read their own entry so the app can confirm access.
    // Staff can read the whole roster; admins manage membership.
    match /allowlist/{email} {
      allow read: if isStaff() || (isSignedIn() && email == emailKey());
      allow write: if isAdmin();
    }

    // /players/{uid}
    // Your hunter card. Any allowlisted member of the party can read everyone's
    // card (party view / DM oversight), but you may only write your own.
    match /players/{uid} {
      allow read: if isAllowlisted();
      allow create, update: if isAllowlisted() && request.auth.uid == uid;
      allow delete: if isAllowlisted() && request.auth.uid == uid;
    }

    // /sessions/{id}
    // Anyone in the party can read the schedule. Only staff (admin/moderator/DM)
    // can create, edit or remove dates.
    match /sessions/{id} {
      allow read: if isAllowlisted();
      allow write: if isStaff();

      // /sessions/{id}/rsvps/{uid}
      // Each member sets their own attendance; everyone in the party can read
      // attendance (so the DM sees who hasn't answered).
      match /rsvps/{uid} {
        allow read: if isAllowlisted();
        allow write: if isAllowlisted() && request.auth.uid == uid;
      }
    }

    // /games/{gameId}
    // Live play instances. Anyone in the party can see the current game (lobby,
    // active state, recap). Only staff (admin/moderator/DM) start and control a
    // game, and only the game's own DM (or an admin) may update or remove it.
    match /games/{gameId} {
      allow read: if isAllowlisted();
      allow create: if isStaff() && request.resource.data.dmUid == request.auth.uid;
      allow update, delete: if isAdmin()
        || (isStaff() && resource.data.dmUid == request.auth.uid);

      // /games/{gameId}/participants/{uid}
      // Each member manages their own presence; the game's DM (or an admin) can
      // manage anyone (e.g. remove a player from the lobby).
      match /participants/{uid} {
        allow read: if isAllowlisted();
        allow write: if isAllowlisted()
          && (request.auth.uid == uid
              || isAdmin()
              || get(/databases/$(database)/documents/games/$(gameId)).data.dmUid == request.auth.uid);
      }
    }

    // Lock everything else down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
