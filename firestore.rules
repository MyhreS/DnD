rules_version = '2';

// Catacombs & Starspawns — Firestore security rules.
//
// Open access: anyone signed in with a verified Google account may use the app.
// Permissions are per-campaign: you see a campaign's data only if you're a
// member, and you control a campaign only if you're its DM (its creator).
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Any verified signed-in user.
    function isUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function emailKey() {
      return request.auth.token.email;
    }

    // Super-admin (manages the legacy allowlist; not required for normal use).
    function isSuperAdmin() {
      return isUser() && emailKey() in ["simonmyhre1@gmail.com"];
    }

    // You belong to campaign `cid`.
    function isMember(cid) {
      return isUser()
        && exists(/databases/$(database)/documents/campaigns/$(cid)/members/$(request.auth.uid));
    }

    // You are the DM (creator) of campaign `cid`.
    function isCampaignDM(cid) {
      return isUser()
        && get(/databases/$(database)/documents/campaigns/$(cid)).data.dmUid == request.auth.uid;
    }

    // Parent campaign of a game / session (for subcollection scoping).
    function gameCampaignId(gid) {
      return get(/databases/$(database)/documents/games/$(gid)).data.campaignId;
    }
    function sessionCampaignId(sid) {
      return get(/databases/$(database)/documents/sessions/$(sid)).data.campaignId;
    }

    // /allowlist — legacy/optional. Self + super-admin read; super-admin writes.
    match /allowlist/{email} {
      allow read: if isSuperAdmin() || (isSignedIn() && email == emailKey());
      allow write: if isSuperAdmin();
    }

    // /users/{uid} — a signed-in user's self-set profile (name). Owner only.
    match /users/{uid} {
      allow read, write: if isUser() && request.auth.uid == uid;
    }

    // /characters/{id}
    // Any signed-in user can view character sheets. You write your own; the DM of
    // the campaign a hunter is currently in can manage it (confirm death/recover).
    match /characters/{id} {
      allow read: if isUser();
      allow create: if isUser() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isUser() && (
        resource.data.ownerUid == request.auth.uid
        || (resource.data.campaignId != null && isCampaignDM(resource.data.campaignId))
      );
    }

    // /archive/{id} — transient dead/deleted hunters (purged when a game ends).
    match /archive/{id} {
      allow read, create, delete: if isUser();
    }

    // /campaigns/{id} — a campaign/server and its membership.
    match /campaigns/{id} {
      allow read: if isUser();
      allow create: if isUser() && request.resource.data.dmUid == request.auth.uid;
      allow update: if isUser(); // joining adds yourself to memberUids
      allow delete: if isCampaignDM(id);

      match /members/{uid} {
        allow read: if isUser();
        allow write: if isUser() && (request.auth.uid == uid || isCampaignDM(id));
      }
    }

    // /sessions/{id} — campaign schedule. Members read; the DM manages dates.
    match /sessions/{id} {
      allow read: if isMember(resource.data.campaignId);
      allow create: if isCampaignDM(request.resource.data.campaignId);
      allow update, delete: if isCampaignDM(resource.data.campaignId);

      match /rsvps/{uid} {
        allow read: if isMember(sessionCampaignId(id));
        allow write: if request.auth.uid == uid && isMember(sessionCampaignId(id));
      }
    }

    // /games/{gameId} — live play, owned by its DM; members read.
    match /games/{gameId} {
      allow read: if isMember(resource.data.campaignId);
      allow create: if isCampaignDM(request.resource.data.campaignId)
        && request.resource.data.dmUid == request.auth.uid;
      allow update, delete: if resource.data.dmUid == request.auth.uid;

      match /participants/{uid} {
        allow read: if isMember(gameCampaignId(gameId));
        allow write: if isMember(gameCampaignId(gameId))
          && (request.auth.uid == uid || isCampaignDM(gameCampaignId(gameId)));
      }

      match /loot/{lootId} {
        allow read, create, update: if isMember(gameCampaignId(gameId));
        allow delete: if isCampaignDM(gameCampaignId(gameId));
      }

      // Combat tracker: members read the initiative tracker; only the DM edits it.
      match /combatants/{cid} {
        allow read: if isMember(gameCampaignId(gameId));
        allow write: if isCampaignDM(gameCampaignId(gameId));
      }
    }

    // /trades/{tradeId} — player↔player, settled by the settleTrade Cloud
    // Function (Admin SDK, bypasses these rules). Members read (DM log); the
    // offerer creates; either party may accept/decline/cancel.
    match /trades/{tradeId} {
      allow read: if isMember(resource.data.campaignId);
      allow create: if isMember(request.resource.data.campaignId)
        && request.resource.data.fromUid == request.auth.uid;
      allow update: if isMember(resource.data.campaignId)
        && request.auth.uid in [resource.data.fromUid, resource.data.toUid]
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.status in ["accepted", "declined", "cancelled"];
      allow delete: if isCampaignDM(resource.data.campaignId);
    }

    // /shopListings/{id} — the DM's per-campaign storefront. Members browse; the
    // DM stocks/prices/pulls items. Buying mutates the buyer's own /characters
    // doc (covered by the owner-write rule above).
    match /shopListings/{id} {
      allow read: if isMember(resource.data.campaignId);
      allow create: if isCampaignDM(request.resource.data.campaignId);
      allow update, delete: if isCampaignDM(resource.data.campaignId);
    }

    // /sellRequests/{id} — a player asks to sell an item; the DM prices then
    // approves (crediting the seller's own character) or declines. A request is
    // raised unpriced ("requested"); only the DM may price/approve/decline, and
    // the seller may cancel (declined).
    match /sellRequests/{id} {
      allow read: if isMember(resource.data.campaignId);
      allow create: if isMember(request.resource.data.campaignId)
        && request.resource.data.sellerUid == request.auth.uid
        && request.resource.data.priceGp == null
        && request.resource.data.status == "requested";
      allow update: if isCampaignDM(resource.data.campaignId)
        || (request.auth.uid == resource.data.sellerUid
            && request.resource.data.status == "declined");
      allow delete: if isCampaignDM(resource.data.campaignId);
    }

    // Lock everything else down by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
